# Example systemd timer that fires pv-agent every 15 minutes.
# Not enabled by default.
# Copy to /etc/systemd/system/pv-agent.timer alongside pv-agent.service.

[Unit]
Description=Run pv-agent every 15 minutes

[Timer]
OnBootSec=2min
OnUnitActiveSec=15min
AccuracySec=30s
Persistent=true
Unit=pv-agent.service

[Install]
WantedBy=timers.target
